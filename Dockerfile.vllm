# vLLM on DGX Spark (GB10 / Blackwell sm_121)
#
# The upstream vllm/vllm-openai image is built against CUDA 12.x and lacks
# native sm_121 kernels, causing JIT compilation failures on GB10.
# This image builds on NGC PyTorch 26.01 which ships CUDA 13.1 with full
# sm_121 support — same base used for Docling.
#
# Build:
#   docker compose build vllm
#
# The model is specified at runtime via VLLM_MODEL (see docker-compose.yml).
# HuggingFace gated models require HUGGING_FACE_HUB_TOKEN to be set.

FROM nvcr.io/nvidia/pytorch:26.01-py3

# vLLM requires packaging and a few build-time deps before pip install
RUN pip install --no-cache-dir --upgrade pip setuptools wheel packaging

# Install vLLM — this pulls the right CUDA-aware binaries automatically
# because the NGC base already has CUDA 13.1 headers and libcuda.
RUN pip install --no-cache-dir vllm

EXPOSE 8000

# Model and serving flags are passed via `command:` in docker-compose so they
# can be overridden per deployment without rebuilding the image.
ENTRYPOINT ["python", "-m", "vllm.entrypoints.openai.api_server"]
