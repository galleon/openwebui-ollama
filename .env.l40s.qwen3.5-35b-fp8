# ── Preset: L40S (48 GB GDDR6) + Qwen/Qwen3.5-35B-A3B-FP8 ───────────────────
# Usage: cp .env.l40s.qwen3.5-35b-fp8 .env && docker compose up -d vllm
#
# Note: L40S is Ada Lovelace (sm_89), not Blackwell.
# FP8 Tensor Cores are natively supported on sm_89 — correct choice over NVFP4.
# The standard NGC vLLM image supports sm_89 — no custom build needed.
# The embedder/docling images (Dockerfile.infinity, Dockerfile.docling) are
# built on NGC PyTorch 26.01 (CUDA 13.x, sm_121). They may fall back to JIT
# compilation on sm_89 — use upstream images if startup is too slow:
#   embedder: michaelfeil/infinity:latest
#   docling:  quay.io/docling-project/docling-serve-cu128:latest

# ── Ports ─────────────────────────────────────────────────────────────────────
WEBUI_PORT=3000
DOCLING_PORT=5001
VLLM_PORT=8000
EMBEDDER_PORT=7997

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
WEBUI_SECRET_KEY=changeme-replace-this
OPENAI_API_KEY=EMPTY

# ── GPU: L40S (48 GB GDDR6) ───────────────────────────────────────────────────
VLLM_NGC_TAG=26.03-py3
VLLM_GPU_MEMORY_UTILIZATION=0.90

# ── Model: Qwen3.5-35B-A3B-FP8 ───────────────────────────────────────────────
VLLM_MODEL=Qwen/Qwen3.5-35B-A3B-FP8
OPENWEBUI_MODEL=Qwen/Qwen3.5-35B-A3B-FP8
VLLM_REASONING_PARSER_PLUGIN=/vllm_plugins/noop.py
VLLM_REASONING_PARSER=qwen3
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_FLASHINFER_MOE_BACKEND=throughput

# ── vLLM tuning ───────────────────────────────────────────────────────────────
# L40S: 48 GB × 0.90 = 43.2 GB for vLLM; model ~35 GB → ~8 GB KV cache
# MAX_MODEL_LEN kept at 8192 to maximise concurrent sequences within KV budget
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_NUM_SEQS=32
VLLM_KV_CACHE_DTYPE=fp8
HUGGING_FACE_HUB_TOKEN=

# ── Embedder ──────────────────────────────────────────────────────────────────
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_DEVICE=cuda
EMBEDDER_BATCH_SIZE=32
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_OPENAI_API_KEY=EMPTY
RAG_OPENAI_BATCH_SIZE=32

# ── Reranker ──────────────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cuda
RERANKER_PORT=7998
RERANKER_BATCH_SIZE=32
ENABLE_RAG_HYBRID_SEARCH=true
RAG_RERANKING_ENGINE=external
RAG_EXTERNAL_RERANKER_URL=http://reranker:7998/rerank
RAG_EXTERNAL_RERANKER_API_KEY=EMPTY
RAG_TOP_K=5
RAG_TOP_K_RERANKER=3

# ── Docling ───────────────────────────────────────────────────────────────────
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
DOCLING_WORKERS=2

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_DB=qdrant
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=true
QDRANT_GRPC_PORT=6334
QDRANT_HTTP_PORT=6333

# ── Benchmarking ──────────────────────────────────────────────────────────────
OPENWEBUI_API_KEY=
OPENWEBUI_KB_ID=
