# ── Preset: RTX Pro 6000 Blackwell + AxionML/Qwen3.5-35B-A3B-NVFP4 ────────────
# Usage: cp .env.rtx-pro-6000.qwen3.5-35b-nvfp4 .env && docker compose up -d vllm
#
# Community NVFP4 quantization via NVIDIA TensorRT Model Optimizer (~20 GB).
# No plugin download needed — qwen3 reasoning parser is built into vLLM.

# ── Ports ─────────────────────────────────────────────────────────────────────
# On Brev, only a limited set of ports are exposed externally. Port 8888 is
# available because Brev runs JupyterLab there by default — stop Jupyter first
# (see README Brev section), then Open WebUI takes over that port.
WEBUI_PORT=8888
DOCLING_PORT=5001
VLLM_PORT=8000
EMBEDDER_PORT=7997

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
WEBUI_SECRET_KEY=changeme-replace-this
OPENAI_API_KEY=EMPTY

# ── GPU: RTX Pro 6000 Blackwell (96 GB GDDR7) ────────────────────────────────
VLLM_NGC_TAG=26.03-py3
VLLM_GPU_MEMORY_UTILIZATION=0.55

# ── Model: Qwen3.5-35B-A3B-NVFP4 ─────────────────────────────────────────────
VLLM_MODEL=AxionML/Qwen3.5-35B-A3B-NVFP4
OPENWEBUI_MODEL=AxionML/Qwen3.5-35B-A3B-NVFP4
VLLM_REASONING_PARSER_PLUGIN=/vllm_plugins/noop.py
VLLM_REASONING_PARSER=qwen3
VLLM_USE_FLASHINFER_MOE_FP4=1
VLLM_FLASHINFER_MOE_BACKEND=throughput

# ── vLLM tuning ───────────────────────────────────────────────────────────────
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=32768
VLLM_MAX_NUM_SEQS=64
VLLM_KV_CACHE_DTYPE=fp8
HUGGING_FACE_HUB_TOKEN=

# ── Embedder ──────────────────────────────────────────────────────────────────
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_DEVICE=cuda
EMBEDDER_BATCH_SIZE=32
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_OPENAI_API_KEY=EMPTY
RAG_OPENAI_BATCH_SIZE=32

# ── Reranker ──────────────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cuda
RERANKER_PORT=7998
RERANKER_BATCH_SIZE=32
ENABLE_RAG_HYBRID_SEARCH=true
RAG_RERANKING_ENGINE=external
RAG_EXTERNAL_RERANKER_URL=http://reranker:7998/rerank
RAG_EXTERNAL_RERANKER_API_KEY=EMPTY
RAG_TOP_K=5
RAG_TOP_K_RERANKER=3

# ── Docling ───────────────────────────────────────────────────────────────────
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
DOCLING_WORKERS=2

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_DB=qdrant
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=true
QDRANT_GRPC_PORT=6334
QDRANT_HTTP_PORT=6333

# ── Benchmarking ──────────────────────────────────────────────────────────────
OPENWEBUI_API_KEY=
OPENWEBUI_KB_ID=
