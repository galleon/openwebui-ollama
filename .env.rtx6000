# ── RTX Pro 6000 Blackwell — benchmark environment ────────────────────────────
#
# Optimised for a single NVIDIA RTX Pro 6000 Blackwell (96 GB GDDR7).
# Key differences vs GB10 defaults:
#   - VLLM_GPU_MEMORY_UTILIZATION raised to 0.80 (dedicated VRAM, no CPU sharing)
#   - VLLM_MAX_MODEL_LEN doubled to 65536 (more KV cache headroom)
#   - VLLM_MAX_NUM_SEQS raised to 32 (concurrent load testing)
#   - Docling moved to CPU (saves ~9 GB VRAM for vLLM KV cache)
#   - Reranker enabled by default (included in --profile reranker)
#
# Usage:
#   cp .env.rtx6000 .env
#   docker compose --profile reranker -f docker-compose.yml \
#                  -f docker-compose.rtx6000.yml up -d

# ── Ports ─────────────────────────────────────────────────────────────────────
WEBUI_PORT=8888
DOCLING_PORT=5001
VLLM_PORT=8000
EMBEDDER_PORT=7997

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
WEBUI_SECRET_KEY=replace-with-a-strong-random-secret
OPENAI_API_KEY=EMPTY

# ── HuggingFace model cache ───────────────────────────────────────────────────
HF_CACHE_DIR=./hf_cache

# ── vLLM ──────────────────────────────────────────────────────────────────────
VLLM_NGC_TAG=26.02-py3
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=65536        # double the GB10 default — more KV cache headroom
VLLM_MAX_NUM_SEQS=32            # raised for concurrent load testing
# RTX Pro 6000 has 96 GB dedicated VRAM — safe to push higher than GB10's 0.55.
# At 0.80: ~77 GB for vLLM (weights ~15 GB + KV cache ~62 GB).
# Docling is on CPU (see docker-compose.rtx6000.yml), freeing ~9 GB.
VLLM_GPU_MEMORY_UTILIZATION=0.80
VLLM_KV_CACHE_DTYPE=fp8
VLLM_USE_FLASHINFER_MOE_FP4=1
VLLM_FLASHINFER_MOE_BACKEND=throughput
HUGGING_FACE_HUB_TOKEN=

# ── Embedder ──────────────────────────────────────────────────────────────────
EMBEDDER_MODEL=BAAI/bge-m3
EMBEDDER_BATCH_SIZE=32
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_OPENAI_API_KEY=EMPTY
RAG_OPENAI_BATCH_SIZE=32

# ── Reranker ──────────────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_PORT=7998
RERANKER_BATCH_SIZE=32
ENABLE_RAG_HYBRID_SEARCH=true   # enabled — reranker is part of the benchmark
RAG_RERANKING_ENGINE=external
RAG_EXTERNAL_RERANKER_URL=http://reranker:7998/rerank
RAG_EXTERNAL_RERANKER_API_KEY=EMPTY
RAG_TOP_K=5
RAG_TOP_K_RERANKER=3

# ── Docling (CPU — see docker-compose.rtx6000.yml) ────────────────────────────
# RTX Pro 6000 host CPU — adjust to available cores
OMP_NUM_THREADS=16
MKL_NUM_THREADS=16
DOCLING_WORKERS=2

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_DB=chroma
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_GRPC_PORT=6334
QDRANT_TIMEOUT=5
QDRANT_HTTP_PORT=6333

# ── Benchmarking ──────────────────────────────────────────────────────────────
OPENWEBUI_API_KEY=
OPENWEBUI_KB_ID=
OPENWEBUI_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4
