# ── Ports ─────────────────────────────────────────────────────────────────────
WEBUI_PORT=8888
DOCLING_PORT=5001
VLLM_PORT=8000

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
# IMPORTANT: change this before first run
WEBUI_SECRET_KEY=replace-with-a-strong-random-secret
OPENAI_API_KEY=EMPTY

# ── HuggingFace model cache ───────────────────────────────────────────────────
# Bind-mounted into vLLM and Open WebUI containers.
# Models are downloaded once and reused across restarts and `docker compose down`.
HF_CACHE_DIR=./hf_cache

# ── vLLM (inference) ──────────────────────────────────────────────────────────
# Official NVIDIA NGC vLLM image — no custom build needed.
# Check for newer tags at: https://catalog.ngc.nvidia.com/orgs/nvidia/containers/vllm
VLLM_NGC_TAG=26.03-py3

# Model — FP16 or FP8 only. NVFP4 is Blackwell-exclusive and will not load on L40S.
# Default: Qwen3.5-35B-A3B-FP8 (35B MoE, 3B active params — fits on single L40S)
VLLM_MODEL=Qwen/Qwen3.5-35B-A3B-FP8

# For Nemotron-3-Nano, use the override instead:
#   docker compose -f docker-compose.yml -f docker-compose.nemotron.yml up -d
#   VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B   # non-NVFP4 checkpoint

VLLM_TENSOR_PARALLEL_SIZE=1     # set to number of GPUs for multi-GPU models
VLLM_MAX_MODEL_LEN=32768
VLLM_MAX_NUM_SEQS=32
# Single L40S (45 GB): embedder + Docling run on CPU, vLLM gets the full card.
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_KV_CACHE_DTYPE=fp8
VLLM_TOOL_CALL_PARSER=qwen3_coder
VLLM_REASONING_PARSER=qwen3

# Required for gated models (Llama, Mistral, …)
HUGGING_FACE_HUB_TOKEN=

# ── RAG / Embeddings ──────────────────────────────────────────────────────────
# Open WebUI built-in sentence-transformers (CPU) — no external service needed.
RAG_EMBEDDING_MODEL=BAAI/bge-m3

# ── Reranker (hybrid search) ──────────────────────────────────────────────────
# Built-in cross-encoder (CPU). Set ENABLE_RAG_HYBRID_SEARCH=true to activate.
ENABLE_RAG_HYBRID_SEARCH=false
RAG_RERANKING_MODEL=BAAI/bge-reranker-v2-m3
RAG_TOP_K=5
RAG_TOP_K_RERANKER=3

# ── Docling ───────────────────────────────────────────────────────────────────
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
DOCLING_WORKERS=2

# ── Vector store (optional — activate with --profile qdrant) ──────────────────
# Default: chroma (built-in). To use Qdrant: set VECTOR_DB=qdrant
VECTOR_DB=chroma
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_GRPC_PORT=6334
QDRANT_TIMEOUT=5
QDRANT_HTTP_PORT=6333

# ── Benchmarking (locustfile.py) ──────────────────────────────────────────────
# Generate an API key in Open WebUI → Settings → Account → API Keys
OPENWEBUI_API_KEY=
# Knowledge base UUID — get via:
#   curl http://localhost:3000/api/v1/knowledge \
#     -H "Authorization: Bearer $OPENWEBUI_API_KEY" | jq '.[].id'
OPENWEBUI_KB_ID=
OPENWEBUI_MODEL=Qwen/Qwen3.5-35B-A3B-FP8
