# ── Ports ─────────────────────────────────────────────────────────────────────
WEBUI_PORT=3000
OLLAMA_PORT=11434
DOCLING_PORT=5001

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
# IMPORTANT: change this before first run
WEBUI_SECRET_KEY=replace-with-a-strong-random-secret

# ── RAG / Embeddings ──────────────────────────────────────────────────────────
RAG_EMBEDDING_ENGINE=ollama
# Pull this model first: docker exec ollama ollama pull nomic-embed-text
RAG_EMBEDDING_MODEL=nomic-embed-text
ENABLE_RAG_HYBRID_SEARCH=false

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_NUM_PARALLEL=4
# GB10 unified memory note: each loaded model stays resident in the shared
# 128 GB pool. Lower this to 1 if running vLLM alongside Ollama.
OLLAMA_MAX_LOADED_MODELS=2

# ── Docling (GB10 thread tuning) ──────────────────────────────────────────────
# Grace CPU has 72 Arm cores — tune these to your workload
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
DOCLING_WORKERS=2

# ── Embedder (optional GPU embedding server) ─────────────────────────────────
# Activate with: docker compose --profile embedder up -d
# Then switch Open WebUI from Ollama to this server:
#   RAG_EMBEDDING_ENGINE=openai
#   RAG_EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDER_MODEL=BAAI/bge-m3      # any sentence-transformers model on HF Hub
EMBEDDER_PORT=7997
EMBEDDER_BATCH_SIZE=32

# Open WebUI connection to embedder (only used when RAG_EMBEDDING_ENGINE=openai)
RAG_EMBEDDING_ENGINE=ollama     # switch to: openai
RAG_EMBEDDING_MODEL=nomic-embed-text  # switch to: BAAI/bge-m3
RAG_OPENAI_API_BASE_URL=http://embedder:7997/v1
RAG_OPENAI_API_KEY=EMPTY
RAG_OPENAI_BATCH_SIZE=32

# ── Reranker (optional GPU reranking server) ──────────────────────────────────
# Activate with: docker compose --profile reranker up -d
# Then enable hybrid search in Open WebUI:
#   ENABLE_RAG_HYBRID_SEARCH=true
#   RAG_RERANKING_ENGINE=external
RERANKER_MODEL=BAAI/bge-reranker-v2-m3   # multilingual cross-encoder
RERANKER_PORT=7998
RERANKER_BATCH_SIZE=32

# Open WebUI connection to reranker
ENABLE_RAG_HYBRID_SEARCH=false  # switch to: true
RAG_RERANKING_ENGINE=           # switch to: external
RAG_EXTERNAL_RERANKER_URL=http://reranker:7998/rerank
RAG_EXTERNAL_RERANKER_API_KEY=EMPTY
RAG_TOP_K=5
RAG_TOP_K_RERANKER=3

# ── vLLM (optional OpenAI-compatible inference server) ───────────────────────
# Activate with: docker compose --profile vllm up -d
# Then set OPENAI_API_BASE_URL so Open WebUI discovers the vLLM models.
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_PORT=8000
VLLM_TENSOR_PARALLEL_SIZE=1     # set to number of GPUs for multi-GPU models
VLLM_MAX_MODEL_LEN=8192
# ⚠️  GB10 unified memory warning:
# The GPU sees the full 128 GB shared pool. At 0.90 vLLM would pre-allocate
# ~102 GB for KV cache, starving all other containers.
# Recommended values:
#   vLLM alone (no Ollama inference models loaded): 0.60  → ~68 GB KV cache
#   vLLM + embedder + reranker + Docling:           0.35  → ~40 GB KV cache
#   vLLM + Ollama models both resident:             0.25  → ~28 GB KV cache
VLLM_GPU_MEMORY_UTILIZATION=0.35
# Required for gated models (Llama, Mistral, …)
HUGGING_FACE_HUB_TOKEN=

# Open WebUI connection to vLLM — leave blank to disable
# When --profile vllm is active, set this to: http://vllm:8000/v1
OPENAI_API_BASE_URL=
OPENAI_API_KEY=EMPTY

# ── Vector store ─────────────────────────────────────────────────────────────
# Default: chroma (built-in, no extra service needed)
# To use Qdrant: set VECTOR_DB=qdrant and start with --profile qdrant
#   docker compose --profile qdrant up -d
VECTOR_DB=chroma

# Qdrant connection (only used when VECTOR_DB=qdrant)
# Leave QDRANT_URI as-is to target the bundled qdrant service.
# Override with an external URL if you manage your own Qdrant instance.
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_GRPC_PORT=6334
# QDRANT_TIMEOUT=30

# Qdrant service ports (only relevant when using --profile qdrant)
QDRANT_HTTP_PORT=6333

# ── Benchmarking (locustfile.py) ──────────────────────────────────────────────
# Generate an API key in Open WebUI → Settings → Account → API Keys
OPENWEBUI_API_KEY=
# Knowledge base UUID — get via:
#   curl http://localhost:3000/api/v1/knowledge \
#     -H "Authorization: Bearer $OPENWEBUI_API_KEY" | jq '.[].id'
OPENWEBUI_KB_ID=
# Model to use for benchmark queries (must be pulled in Ollama)
OPENWEBUI_MODEL=llama3.2
