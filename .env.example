# ── Ports ─────────────────────────────────────────────────────────────────────
WEBUI_PORT=3000
OLLAMA_PORT=11434
DOCLING_PORT=5001

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
# IMPORTANT: change this before first run
WEBUI_SECRET_KEY=replace-with-a-strong-random-secret

# ── RAG / Embeddings ──────────────────────────────────────────────────────────
RAG_EMBEDDING_ENGINE=ollama
# Pull this model first: docker exec ollama ollama pull nomic-embed-text
RAG_EMBEDDING_MODEL=nomic-embed-text
ENABLE_RAG_HYBRID_SEARCH=false

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2

# ── Docling (GB10 thread tuning) ──────────────────────────────────────────────
# Grace CPU has 72 Arm cores — tune these to your workload
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
DOCLING_WORKERS=2

# ── vLLM (optional OpenAI-compatible inference server) ───────────────────────
# Activate with: docker compose --profile vllm up -d
# Then set OPENAI_API_BASE_URL so Open WebUI discovers the vLLM models.
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_PORT=8000
VLLM_TENSOR_PARALLEL_SIZE=1     # set to number of GPUs for multi-GPU models
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.90
# Required for gated models (Llama, Mistral, …)
HUGGING_FACE_HUB_TOKEN=

# Open WebUI connection to vLLM — leave blank to disable
# When --profile vllm is active, set this to: http://vllm:8000/v1
OPENAI_API_BASE_URL=
OPENAI_API_KEY=EMPTY

# ── Vector store ─────────────────────────────────────────────────────────────
# Default: chroma (built-in, no extra service needed)
# To use Qdrant: set VECTOR_DB=qdrant and start with --profile qdrant
#   docker compose --profile qdrant up -d
VECTOR_DB=chroma

# Qdrant connection (only used when VECTOR_DB=qdrant)
# Leave QDRANT_URI as-is to target the bundled qdrant service.
# Override with an external URL if you manage your own Qdrant instance.
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_GRPC_PORT=6334
# QDRANT_TIMEOUT=30

# Qdrant service ports (only relevant when using --profile qdrant)
QDRANT_HTTP_PORT=6333

# ── Benchmarking (locustfile.py) ──────────────────────────────────────────────
# Generate an API key in Open WebUI → Settings → Account → API Keys
OPENWEBUI_API_KEY=
# Knowledge base UUID — get via:
#   curl http://localhost:3000/api/v1/knowledge \
#     -H "Authorization: Bearer $OPENWEBUI_API_KEY" | jq '.[].id'
OPENWEBUI_KB_ID=
# Model to use for benchmark queries (must be pulled in Ollama)
OPENWEBUI_MODEL=llama3.2
