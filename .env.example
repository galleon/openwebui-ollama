# ── Ports ─────────────────────────────────────────────────────────────────────
WEBUI_PORT=3000
OLLAMA_PORT=11434
DOCLING_PORT=5001

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
# MANDATORY: change this before first run — the container will not start without it.
# Generate a strong random value, e.g.: openssl rand -hex 32
WEBUI_SECRET_KEY=replace-with-a-strong-random-secret

# ── RAG / Embeddings ──────────────────────────────────────────────────────────
RAG_EMBEDDING_ENGINE=ollama
# Pull this model first: docker exec ollama ollama pull nomic-embed-text
RAG_EMBEDDING_MODEL=nomic-embed-text
ENABLE_RAG_HYBRID_SEARCH=false

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2

# ── Docling (GB10 thread tuning) ──────────────────────────────────────────────
# Grace CPU has 72 Arm cores — tune these to your workload
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
DOCLING_WORKERS=2

# ── Docling service settings ──────────────────────────────────────────────────
DOCLING_SERVE_ENABLE_UI=true
DOCLING_SERVE_ENABLE_REMOTE_SERVICES=true
# Maximum seconds to wait for a synchronous extraction request (large docs may need more)
DOCLING_SERVE_MAX_SYNC_WAIT=600
# Number of uvicorn workers (keep at 1 to avoid "Task Not Found" errors)
UVICORN_WORKERS=1
# PDF backend: pypdfium2 (default, fast) or docling_parse (for malformed PDFs)
DOCLING_SERVE_PDF_BACKEND=pypdfium2
# Set to false for digital-PDF-only workloads (skips OCR, significant speed gain)
DOCLING_SERVE_PIPELINE_OPTIONS__DO_OCR=true

