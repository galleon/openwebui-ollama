# ── Ports ─────────────────────────────────────────────────────────────────────
WEBUI_PORT=3000
OLLAMA_PORT=11434
DOCLING_PORT=5001

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
# IMPORTANT: change this before first run
WEBUI_SECRET_KEY=replace-with-a-strong-random-secret

# ── RAG / Embeddings ──────────────────────────────────────────────────────────
RAG_EMBEDDING_ENGINE=ollama
# Pull this model first: docker exec ollama ollama pull nomic-embed-text
RAG_EMBEDDING_MODEL=nomic-embed-text
ENABLE_RAG_HYBRID_SEARCH=false

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2

# ── Docling (GB10 thread tuning) ──────────────────────────────────────────────
# Grace CPU has 72 Arm cores — tune these to your workload
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
DOCLING_WORKERS=2
