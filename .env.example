# ── Ports ─────────────────────────────────────────────────────────────────────
WEBUI_PORT=3000
DOCLING_PORT=5001
VLLM_PORT=8000
EMBEDDER_PORT=7997

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_AUTH=true
# IMPORTANT: change this before first run
WEBUI_SECRET_KEY=replace-with-a-strong-random-secret
OPENAI_API_KEY=EMPTY

# ── HuggingFace model cache ───────────────────────────────────────────────────
# Bind-mounted into vLLM, embedder, and reranker containers.
# Models are downloaded once and reused across restarts and `docker compose down`.
# Set an absolute path to share the cache with other projects or host tools.
HF_CACHE_DIR=./hf_cache

# ── vLLM (inference) ──────────────────────────────────────────────────────────
# Any HuggingFace model ID. Gated models require HUGGING_FACE_HUB_TOKEN.
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_TENSOR_PARALLEL_SIZE=1     # set to number of GPUs for multi-GPU models
VLLM_MAX_MODEL_LEN=8192
# GB10 unified memory note: vLLM sees the full 128 GB shared pool.
# At 0.55 with a 7B model: ~14 GB weights + ~63 GB KV cache = ~77 GB total,
# leaving ~51 GB for embedder, reranker, Docling, and OS.
# Raise toward 0.80 if running vLLM alone; lower to 0.35 if adding reranker.
VLLM_GPU_MEMORY_UTILIZATION=0.55
# Required for gated models (Llama, Mistral, …)
HUGGING_FACE_HUB_TOKEN=

# ── Embedder (Infinity — replaces Ollama for RAG embeddings) ──────────────────
# Any sentence-transformers model on HF Hub.
EMBEDDER_MODEL=BAAI/bge-m3      # multilingual, 1024-dim — good default
EMBEDDER_BATCH_SIZE=32
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_OPENAI_API_KEY=EMPTY
RAG_OPENAI_BATCH_SIZE=32

# ── Reranker (optional — activate with --profile reranker) ────────────────────
RERANKER_MODEL=BAAI/bge-reranker-v2-m3   # multilingual cross-encoder
RERANKER_PORT=7998
RERANKER_BATCH_SIZE=32
ENABLE_RAG_HYBRID_SEARCH=false  # switch to: true
RAG_RERANKING_ENGINE=           # switch to: external
RAG_EXTERNAL_RERANKER_URL=http://reranker:7998/rerank
RAG_EXTERNAL_RERANKER_API_KEY=EMPTY
RAG_TOP_K=5
RAG_TOP_K_RERANKER=3

# ── Docling (GB10 thread tuning) ──────────────────────────────────────────────
# Grace CPU has 72 Arm cores — tune these to your workload
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
DOCLING_WORKERS=2

# ── Vector store (optional — activate with --profile qdrant) ──────────────────
# Default: chroma (built-in). To use Qdrant: set VECTOR_DB=qdrant
VECTOR_DB=chroma
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false
QDRANT_GRPC_PORT=6334
# QDRANT_TIMEOUT=30
QDRANT_HTTP_PORT=6333

# ── Benchmarking (locustfile.py) ──────────────────────────────────────────────
# Generate an API key in Open WebUI → Settings → Account → API Keys
OPENWEBUI_API_KEY=
# Knowledge base UUID — get via:
#   curl http://localhost:3000/api/v1/knowledge \
#     -H "Authorization: Bearer $OPENWEBUI_API_KEY" | jq '.[].id'
OPENWEBUI_KB_ID=
OPENWEBUI_MODEL=Qwen/Qwen2.5-7B-Instruct
